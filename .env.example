# APP_ENV: unset or test → .env.test first, then .env if DATABASE_URL still empty.
#           live/production/etc. → .env only.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/likespotifybot?sslmode=disable

# Spotify OAuth (required for connect flow)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Must match a Redirect URI in the Spotify Developer Dashboard exactly
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8080

HTTP_LISTEN_ADDR=127.0.0.1:8080
ENABLE_ANALYTICS=true

# Adaptive playback polling (milliseconds unless noted)
POLL_INTERVAL_PLAYING_MS=2000
POLL_INTERVAL_PAUSED_MS=5000
POLL_INTERVAL_INACTIVE_MS=60000
POLL_PAUSED_SLOW_AFTER_MS=15000
POLL_INACTIVE_AFTER_SECONDS=180
# Higher = more sensitive stall detection (0.85–0.95). Catches shorter pauses between polls.
GESTURE_STALL_SLACK_RATIO=0.90

# Gesture: max pause duration for quick pause → like (milliseconds)
GESTURE_QUICK_PAUSE_MAX_MS=4000
GESTURE_COOLDOWN_SECONDS=30

# Telegram notification when a track is saved
NOTIFY_ON_GESTURE=true

SPOTIFY_API_MAX_RETRIES=3
GET_UPDATES_TIMEOUT_SECONDS=50
